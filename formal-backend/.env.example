PORT=8787

# Only your website should know this token. Change it before deployment.
SITE_ACCESS_TOKEN=change-this-long-random-password

# Your LiblibAI API keys. Never put these in frontend code.
LIBLIB_ACCESS_KEY=your-liblib-access-key
LIBLIB_SECRET_KEY=your-liblib-secret-key

# Allowed frontend origins, comma separated.
# Example: https://lyljh521-ship-it.github.io,http://localhost:8787
ALLOWED_ORIGINS=http://localhost:8787

# Cost controls
MAX_IMAGE_BYTES=8388608
MAX_REQUESTS_PER_HOUR=20
CREDIT_COST_IMAGE2=12
CREDIT_COST_BANANA_PRO=18
CREDIT_COST_LIBLIB=10

# First admin account. The server creates it only when users.json does not exist.
ADMIN_PASSWORD=change-this-admin-password
ADMIN_INITIAL_CREDITS=9999

AI_PROVIDER=image2
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_IMAGE_MODEL=your-image2-model-id
BANANA_PRO_IMAGE_MODEL=your-banana-pro-model-id
OPENAI_API_KEY=your-openai-compatible-api-key
